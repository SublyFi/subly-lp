# Public LP demo toggle.
SUBLY402_DEMO_ENABLED=1

# Use an authenticated Solana devnet RPC endpoint.
# Alchemy Solana Devnet RPC is recommended for the hosted demo.
SUBLY402_DEMO_RPC_URL="https://solana-devnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"

# Live Subly402 facilitator.
SUBLY402_DEMO_FACILITATOR_URL="https://api.demo.sublyfi.com"
SUBLY402_NETWORK="solana:devnet"

# Public Seller host used by the one-click comparison.
# Use http here unless the Seller Express app is configured to trust the nginx
# proxy protocol; payment signatures bind to the exact request origin.
SUBLY402_DEMO_SELLER_BASE_URL="http://seller.demo.sublyfi.com"
SUBLY402_X402_SELLER_URL="http://seller.demo.sublyfi.com/x402/weather"
SUBLY402_SUBLY_SELLER_URL="http://seller.demo.sublyfi.com/subly/weather"
SUBLY402_X402_NETWORK="solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1"
SUBLY402_X402_FACILITATOR_URL="https://x402.org/facilitator"

